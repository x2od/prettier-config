{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["github>x2od/.github:renovate.json5"],
	"packageRules": [
		{
			"matchManagers": ["github-actions"],
			"commitMessageExtra": "from {{currentVersion}} to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{newVersion}}{{else}}{{#if isSingleVersion}}{{newVersion}}{{else}}{{#if newValue}}{{{newVersion}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}"
		}
	],
	"major": { "autoApprove": true, "automerge": false, "addLabels": ["renovate", "major"] },
	"minor": { "autoApprove": true, "automerge": true, "addLabels": ["renovate", "minor"] },
	"patch": { "autoApprove": true, "automerge": true, "addLabels": ["renovate", "patch"] },
	"dependencyDashboardAutoclose": true,
	"lockFileMaintenance": {
		"enabled": true
	},
	"configWarningReuseIssue": false,
	"rangeStrategy": "widen"
}
