{
	"$schema": "https://json.schemastore.org/prettierrc.json",
	"apexInsertFinalNewline": false,
	"bracketSameLine": true,
	"bracketSpacing": true,
	"endOfLine": "lf",
	"experimentalTernaries": true,
	"printWidth": 180,
	"singleAttributePerLine": false,
	"singleQuote": true,
	"tabWidth": 2,
	"trailingComma": "none",
	"useTabs": true,
	"xmlSelfClosingSpace": true,
	"overrides": [
		{
			"files": "*.{cmp,page,component}",
			"options": {
				"attributeGroups": [
					"^id$",
					"^aura:id$",
					"^name$",
					"^src$",
					"^for$",
					"^type$",
					"^href$",
					"^value$",
					"^title$",
					"^alt$",
					"^role$",
					"$DEFAULT",
					"^html-",
					"$TYPE",
					"^access$",
					"^description$",
					"^class$",
					"^data-",
					"$ARIA",
					"^aria-",
					"^on"
				],
				"attributeIgnoreCase": true,
				"parser": "html",
				"singleQuote": false
			}
		},
		{
			"files": "*.{cls,trigger}",
			"options": {
				"parser": "apex",
				"tabWidth": 2,
				"useTabs": true
			}
		},
		{
			"files": "*.trigger",
			"options": {
				"printWidth": 200
			}
		},
		{
			"files": "*.{apex,soql}",
			"options": {
				"parser": "apex-anonymous"
			}
		},
		{
			"files": "['**/pmd/*.xml', 'ruleset.xml']",
			"options": {
				"parser": "xml",
				"useTabs": true,
				"xmlSelfClosingSpace": true,
				"xmlWhitespaceSensitivity": "preserve"
			}
		},
		{
			"files": "*meta.xml",
			"options": {
				"parser": "xml",
				"useTabs": false,
				"xmlSelfClosingSpace": false
			}
		},
		{
			"files": "*.{yml,yaml}",
			"options": {
				"parser": "yaml",
				"singleQuote": true,
				"useTabs": false
			}
		},
		{
			"files": ".prettierrc",
			"options": {
				"printWidth": 80,
				"singleQuote": false,
				"parser": "json"
			}
		},
		{
			"files": "*.json",
			"options": {
				"parser": "json",
				"printWidth": 80,
				"singleQuote": false
			}
		},
		{
			"files": "doc*/**/*.html",
			"options": {
				"attributeGroups": ["$CODE_GUIDE"],
				"htmlWhitespaceSensitivity": "ignore",
				"parser": "html",
				"printWidth": 150,
				"singleQuote": false
			}
		},
		{
			"files": "**/lwc/**/*.html",
			"options": {
				"parser": "lwc",
				"printWidth": 120,
				"attributeGroups": [
					"^lwc",
					"^id$",
					"^name$",
					"^src$",
					"^for$",
					"^type$",
					"^href$",
					"^value$",
					"^title$",
					"^alt$",
					"^role$",
					"^aria-",
					"^html-",
					"$TYPE",
					"^access$",
					"^description$",
					"^class$",
					"^data-",
					"$ARIA",
					"^on"
				]
			}
		},
		{
			"files": "*.json5",
			"options": { "quote-props": "consistent", "parser": "json5" }
		}
	],
	"plugins": [
		"prettier-plugin-apex",
		"@prettier/plugin-xml",
		"prettier-plugin-organize-attributes"
	]
}
